<body class="font-body-md text-body-md min-h-screen flex items-center justify-center relative px-margin-mobile md:px-margin-desktop">
<!-- Decorative Animated Background Elements -->
<div class="aura-glow top-[-10%] left-[-10%]"></div>
<div class="aura-glow bottom-[-10%] right-[-10%]"></div>
<main class="w-full max-w-[480px] z-10">
<!-- Brand Identity -->
<div class="text-center mb-10">
<h1 class="font-headline-lg text-headline-lg font-bold tracking-tight text-on-surface flex items-center justify-center gap-3">
<span class="material-symbols-outlined text-primary text-4xl" style="font-variation-settings: 'FILL' 1;">auto_awesome</span>
                Aura Study
            </h1>
<p class="text-on-surface-variant font-body-md mt-2">Elevate your cognition with focused study tools.</p>
</div>
<!-- Login Glass Card -->
<div class="glass-card rounded-[24px] p-8 md:p-10">
<div class="mb-8">
<h2 class="font-headline-md text-headline-md text-on-surface mb-2">Welcome Back</h2>
<p class="text-on-surface-variant">Sign in to continue your research session.</p>
</div>
<!-- Social Sign In -->
<button class="w-full flex items-center justify-center gap-3 bg-surface-container-high py-3 px-4 rounded-xl border border-white/5 hover:bg-surface-variant transition-colors duration-200 mb-6 group">
<svg class="text-on-surface" fill="currentColor" height="20" viewbox="0 0 24 24" width="20">
<path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"></path>
<path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"></path>
<path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"></path>
<path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"></path>
</svg>
<span class="font-medium">Sign in with Google</span>
</button>
<div class="relative flex items-center justify-center mb-6">
<div class="w-full border-t border-white/10"></div>
<span class="absolute bg-[#141318]/0 px-4 text-label-sm text-outline uppercase tracking-widest">or email</span>
<div class="h-4 w-12 bg-surface absolute blur-sm"></div>
<span class="relative z-10 px-4 text-label-sm text-outline uppercase tracking-widest bg-surface-container-low">or email</span>
</div>
<!-- Login Form -->
<form class="space-y-5" id="loginForm" onsubmit="handleLogin(event)">
<div class="space-y-1.5">
<label class="text-label-sm text-on-surface-variant ml-1" for="email">Email Address</label>
<div class="relative group input-focus-glow rounded-xl transition-all duration-200">
<span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-outline group-focus-within:text-primary transition-colors">mail</span>
<input class="w-full bg-surface-container-low border border-white/5 rounded-xl py-3 pl-12 pr-4 text-on-surface placeholder:text-outline/50 focus:ring-0 focus:border-primary-container transition-all" id="email" placeholder="name@example.com" required="" type="email"/>
</div>
</div>
<div class="space-y-1.5">
<div class="flex justify-between items-center ml-1">
<label class="text-label-sm text-on-surface-variant" for="password">Password</label>
<a class="text-label-sm text-primary hover:underline transition-all" href="#">Forgot password?</a>
</div>
<div class="relative group input-focus-glow rounded-xl transition-all duration-200">
<span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-outline group-focus-within:text-primary transition-colors">lock</span>
<input class="w-full bg-surface-container-low border border-white/5 rounded-xl py-3 pl-12 pr-12 text-on-surface placeholder:text-outline/50 focus:ring-0 focus:border-primary-container transition-all" id="password" placeholder="••••••••" required="" type="password"/>
<button class="absolute right-4 top-1/2 -translate-y-1/2 text-outline hover:text-on-surface transition-colors" onclick="togglePassword()" type="button">
<span class="material-symbols-outlined" id="eyeIcon">visibility</span>
</button>
</div>
</div>
<div class="flex items-center gap-2 px-1">
<input class="w-4 h-4 rounded border-white/10 bg-surface-container-low text-primary focus:ring-primary focus:ring-offset-surface" id="remember" type="checkbox"/>
<label class="text-body-md text-on-surface-variant cursor-pointer select-none" for="remember">Remember this session</label>
</div>
<button class="w-full bg-primary-container text-on-primary-container font-medium py-3.5 rounded-xl hover:brightness-110 active:scale-[0.98] transition-all duration-200 flex items-center justify-center gap-2" type="submit">
                    Start Learning
                    <span class="material-symbols-outlined text-lg">arrow_forward</span>
</button>
</form>
<div class="mt-8 text-center">
<p class="text-on-surface-variant">
                    Don't have an account? 
                    <a class="text-primary font-medium hover:underline" href="signup.html">Join Aura Study</a>
</p>
