<div class="h-[1px] flex-grow bg-white/10"></div>
</div>
<!-- Email/Password Form -->
<form class="flex flex-col gap-5" id="signup-form">
<div class="flex flex-col gap-1.5">
<label class="text-on-surface-variant text-xs font-semibold ml-1" for="name">FULL NAME</label>
<div class="relative">
<span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-on-surface-variant text-xl">person</span>
<input class="w-full bg-surface-container-low border border-outline-variant rounded-xl py-3 pl-12 pr-4 text-on-surface placeholder:text-outline input-focus transition-all" id="name" placeholder="John Doe" required="" type="text"/>
</div>
</div>
<div class="flex flex-col gap-1.5">
<label class="text-on-surface-variant text-xs font-semibold ml-1" for="email">EMAIL ADDRESS</label>
<div class="relative">
<span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-on-surface-variant text-xl">mail</span>
<input class="w-full bg-surface-container-low border border-outline-variant rounded-xl py-3 pl-12 pr-4 text-on-surface placeholder:text-outline input-focus transition-all" id="email" placeholder="name@example.com" required="" type="email"/>
</div>
</div>
<div class="flex flex-col gap-1.5">
<label class="text-on-surface-variant text-xs font-semibold ml-1" for="password">PASSWORD</label>
<div class="relative">
<span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-on-surface-variant text-xl">lock</span>
<input class="w-full bg-surface-container-low border border-outline-variant rounded-xl py-3 pl-12 pr-4 text-on-surface placeholder:text-outline input-focus transition-all" id="password" placeholder="••••••••" required="" type="password"/>
</div>
</div>
<div class="mt-2">
<button class="w-full py-4 bg-primary text-on-primary font-bold rounded-xl btn-hover-effect active:scale-[0.98] transition-all shadow-lg shadow-primary/10" type="submit">
                            Create Account
                        </button>
</div>
</form>
<p class="text-center text-on-surface-variant text-sm mt-2">
