<path d="M12 23c2.97 0 5.46-.98 7.28-2.65l-3.57-2.77c-1.01.68-2.33 1.09-3.71 1.09-2.85 0-5.27-1.92-6.13-4.51H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"></path>
<path d="M5.87 14.16A7.14 7.14 0 0 1 5.4 12c0-.76.13-1.5.37-2.16V7h-3.7C1.34 8.5 1 10.21 1 12s.34 3.5 1.07 5l3.8-2.84z" fill="#FBBC05"></path>
