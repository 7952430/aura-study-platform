<body class="min-h-screen flex flex-col font-body-md text-body-md">
<!-- Ambient Background Elements -->
<div class="aura-glow top-[-200px] left-[-100px]"></div>
<div class="aura-glow bottom-[-200px] right-[-100px]"></div>
<!-- Navigation Shell (TopAppBar) -->
<header class="fixed top-0 w-full bg-surface/80 dark:bg-surface-container/80 backdrop-blur-xl border-b border-white/10 dark:border-white/5 z-50">
<div class="flex justify-between items-center h-16 px-margin-desktop max-w-container-max mx-auto">
<div class="flex items-center gap-2">
<span class="material-symbols-outlined text-primary text-3xl" style="font-variation-settings: 'FILL' 1;">auto_awesome</span>
<span class="font-headline-md text-headline-md font-semibold tracking-tight text-on-surface">Aura Study</span>
</div>
<nav class="hidden md:flex items-center gap-8">
<a class="text-on-surface-variant hover:text-primary transition-colors duration-200" href="#">Home</a>
<a class="text-on-surface-variant hover:text-primary transition-colors duration-200" href="#">Courses</a>
<a class="text-on-surface-variant hover:text-primary transition-colors duration-200" href="#">Subjects</a>
<a class="text-on-surface-variant hover:text-primary transition-colors duration-200" href="login.html">Login</a>
</nav>
<div class="flex items-center gap-4">
<a class="bg-primary text-on-primary px-6 py-2 rounded-full font-medium active:scale-95 transition-all btn-hover-effect" href="#">Start Learning</a>
</div>
</div>
</header>
<!-- Main Content Canvas -->
<main class="flex-grow flex items-center justify-center pt-24 pb-12 px-margin-mobile">
<div class="w-full max-w-md">
<!-- Glassmorphic Signup Card -->
<div class="glass-card p-8 md:p-10 rounded-[24px] flex flex-col gap-6 relative overflow-hidden">
<div class="text-center">
<h1 class="font-headline-lg text-headline-lg text-on-surface mb-2">Create Account</h1>
<p class="text-on-surface-variant font-body-md">Enter the realm of focused learning.</p>
</div>
<!-- Auth Error Message (Hidden by default) -->
<div class="hidden p-3 rounded-lg bg-error-container/20 border border-error/20 text-error text-sm text-center" id="auth-error">
                    Invalid credentials. Please try again.
                </div>
<!-- Google Auth Button -->
<button class="flex items-center justify-center gap-3 w-full py-3 px-4 rounded-xl border border-outline-variant bg-white/5 hover:bg-white/10 transition-all font-medium text-on-surface group" id="google-signup">
